            $parts[] = [
                'inline_data' => [
                    'mime_type' => $image->getMimeType(),
                    'data' => base64_encode(file_get_contents($image->getRealPath())),
                ],
            ];
        }

        $model = $this->getGeminiModel();
        $apiKey = $this->getGeminiApiKey();

        $url = "https://generativelanguage.googleapis.com/v1beta/models/{$model}:generateContent?key={$apiKey}";

        $response = Http::timeout(60)->post($url, [
            'contents' => [
                [
                    'role' => 'user',
                    'parts' => $parts,
                ],
            ],
            'generationConfig' => [
                'temperature' => $this->getGeminiTemperature(),
                'maxOutputTokens' => $this->getGeminiMaxOutputTokens(),
                'responseMimeType' => 'application/json',
            ],
        ]);

        if (!$response->successful()) {
            Log::warning('Gemini waste listing image analysis failed', [
                'status' => $response->status(),
                'body' => $response->body(),
            ]);

            return null;
        }

        $text = data_get($response->json(), 'candidates.0.content.parts.0.text');

        if (!is_string($text) || trim($text) === '') {
            return null;
        }

        return $this->decodeGeminiJson($text);
    }

    private function normalizeItemBreakdownFromCategories(array $analysis, $categories): array
    {
        $items = $analysis['item_breakdown'] ?? [];

        if (!is_array($items)) {
            return [];
        }

        $cleanItems = [];

        foreach ($items as $item) {
            if (!is_array($item)) {
                continue;
            }

            $itemName = trim((string) ($item['item_name'] ?? ''));

            if ($itemName === '') {
                continue;
            }

            $aiCategoryName = trim((string) ($item['category_name'] ?? ''));
            $category = $this->matchItemCategory($itemName, $aiCategoryName, $categories);

            $quantity = max((int) ($item['quantity'] ?? 1), 1);

            $unitWeight = $category && $category->average_weight_kg
                ? (float) $category->average_weight_kg
                : $this->numberOrNull($item['unit_weight_kg'] ?? null);

            if (!$unitWeight || $unitWeight <= 0) {
                $unitWeight = $this->defaultUnitWeight($itemName);
            }

            $totalWeight = $quantity * $unitWeight;

            $pricePerKg = $this->numberOrNull($category?->price_per_kg) ?: 0;
            $pricePerItem = $this->numberOrNull($category?->price_per_item) ?: 0;

            $lineExpectedPrice = $pricePerKg > 0
                ? $totalWeight * $pricePerKg
                : ($pricePerItem > 0 ? $quantity * $pricePerItem : $totalWeight * 700);

            $cleanItems[] = [
                'item_name' => $itemName,
                'category_id' => $category?->id,
                'category_name' => $category?->name ?? ($aiCategoryName ?: $itemName),
                'category_slug' => $category?->slug,
                'quantity' => $quantity,
                'unit_weight_kg' => round($unitWeight, 2),
                'total_weight_kg' => round($totalWeight, 2),
                'min_weight_kg' => $this->numberOrNull($category?->min_weight_kg),
                'max_weight_kg' => $this->numberOrNull($category?->max_weight_kg),
                'price_per_kg' => $pricePerKg,
                'price_per_item' => $pricePerItem,
                'line_expected_price' => round($lineExpectedPrice, 2),
                'is_hazardous' => (bool) ($category?->is_hazardous ?? false),
                'confidence' => min(max((float) ($item['confidence'] ?? 70), 0), 100),
                'reason' => (string) ($item['reason'] ?? 'Matched with standard e-waste category library.'),
            ];
        }

        return $cleanItems;
    }

