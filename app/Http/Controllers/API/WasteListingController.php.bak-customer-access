<?php

namespace App\Http\Controllers\API;

use App\Http\Controllers\API\BaseController as BaseController;
use App\Models\User;
use App\Models\WasteAiAnalysis;
use App\Models\WasteCategory;
use App\Models\WasteListing;
use App\Models\WastePhoto;
use Illuminate\Http\JsonResponse;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Http;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Facades\Validator;
use Illuminate\Validation\Rule;

class WasteListingController extends BaseController
{
    private function isAdmin(User $user): bool
    {
        return $user->role === 'admin';
    }

    private function isStaff(User $user): bool
    {
        return in_array($user->role, ['enviroserve_staff', 'admin'], true);
    }

    private function canView(User $user, WasteListing $listing): bool
    {
        return $this->isStaff($user) || $listing->institution_id === $user->id;
    }

    public function index(Request $request): JsonResponse
    {
        $user = $request->user();

        $query = WasteListing::with([
            'institution:id,name,email,role,institution_name,phone',
            'category',
            'primaryPhoto',
            'latestPickup',
        ]);

        if ($user->role === 'institution') {
            $query->where('institution_id', $user->id);
        }

        if ($request->filled('status') && $request->status !== 'all') {
            $query->where('status', $request->status);
        }

        if ($request->filled('waste_category_id') && $request->waste_category_id !== 'all') {
            $query->where('waste_category_id', $request->waste_category_id);
        }

        if ($request->filled('district')) {
            $query->where('district', $request->district);
        }

        if ($request->filled('search')) {
            $search = trim((string) $request->input('search'));

            $query->where(function ($q) use ($search) {
                $q->where('title', 'like', "%{$search}%")
                    ->orWhere('description', 'like', "%{$search}%")
                    ->orWhere('ai_detected_item', 'like', "%{$search}%")
                    ->orWhere('ai_detected_category', 'like', "%{$search}%");
            });
        }

        $perPage = (int) $request->input('per_page', 15);
        $perPage = max(5, min($perPage, 100));

        $listings = $query->latest()->paginate($perPage);

        return $this->sendResponse($listings, 'Waste listings retrieved successfully.');
    }

    public function store(Request $request): JsonResponse
    {
        $user = $request->user();

        $allowedListingRoles = ['customer', 'company', 'institution', 'admin'];

        if (!in_array($user->role, $allowedListingRoles, true)) {
            return $this->sendError(
                'Access denied.',
                ['error' => 'Only institution or admin can upload waste.'],
                403
            );
        }

        $validator = Validator::make($request->all(), [
            'institution_id' => ['nullable', 'exists:users,id'],
            'waste_category_id' => ['nullable', 'exists:waste_categories,id'],
            'title' => ['required', 'string', 'max:255'],
            'description' => ['nullable', 'string'],
            'quantity' => ['nullable', 'integer', 'min:1'],
            'estimated_weight_kg' => ['nullable', 'numeric', 'min:0'],
            'expected_price' => ['nullable', 'numeric', 'min:0'],
            'currency' => ['nullable', 'string', 'max:10'],
            'pickup_address' => ['nullable', 'string'],
            'district' => ['nullable', 'string', 'max:100'],
            'sector' => ['nullable', 'string', 'max:100'],
            'cell' => ['nullable', 'string', 'max:100'],
            'village' => ['nullable', 'string', 'max:100'],
            'latitude' => ['nullable', 'numeric'],
            'longitude' => ['nullable', 'numeric'],
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation Error.', $validator->errors(), 422);
        }

        $quantity = max((int) $request->input('quantity', 1), 1);
        $category = null;
        $estimatedWeight = $this->numberOrNull($request->input('estimated_weight_kg'));
        $expectedPrice = $this->numberOrNull($request->input('expected_price'));

        if ($request->filled('waste_category_id')) {
            $category = WasteCategory::find($request->input('waste_category_id'));

            if (!$estimatedWeight && $category && $category->average_weight_kg) {
                $estimatedWeight = $quantity * (float) $category->average_weight_kg;
            }

            if (!$expectedPrice && $category) {
                $expectedPrice = $this->calculateExpectedPrice(
                    $category,
                    $quantity,
                    $estimatedWeight,
                    'single_item'
                );
            }
        }

        $listing = WasteListing::create([
            'institution_id' => $user->role === 'admin'
                ? $request->input('institution_id', $user->id)
                : $user->id,

            'waste_category_id' => $request->input('waste_category_id'),
            'title' => $request->input('title'),
            'description' => $request->input('description'),
            'quantity' => $quantity,
            'estimated_weight_kg' => $estimatedWeight,
            'expected_price' => $expectedPrice,
            'currency' => $request->input('currency', 'RWF'),

            'pickup_address' => $request->input('pickup_address'),
            'district' => $request->input('district'),
            'sector' => $request->input('sector'),
            'cell' => $request->input('cell'),
            'village' => $request->input('village'),
            'latitude' => $request->input('latitude'),
            'longitude' => $request->input('longitude'),

            'status' => 'pending',
        ]);

        return $this->sendResponse(
            $listing->load(['institution:id,name,email,role,institution_name', 'category']),
            'Waste listing created successfully.'
        );
    }

    public function aiPreview(Request $request): JsonResponse
    {
        $user = $request->user();

        $allowedListingRoles = ['customer', 'company', 'institution', 'admin'];

        if (!in_array($user->role, $allowedListingRoles, true)) {
            return $this->sendError(
                'Access denied.',
                ['error' => 'Only institution or admin can analyze waste listing.'],
                403
            );
        }

        $validator = Validator::make($request->all(), [
            'name' => ['nullable', 'string', 'max:255'],
            'title' => ['nullable', 'string', 'max:255'],
            'description' => ['nullable', 'string'],
            'quantity' => ['nullable', 'integer', 'min:1'],
            'waste_category_id' => ['nullable', 'exists:waste_categories,id'],
            'image' => ['nullable', 'image', 'mimes:jpg,jpeg,png,webp', 'max:5120'],
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation Error.', $validator->errors(), 422);
        }

        if (!$request->filled('name') && !$request->filled('title') && !$request->hasFile('image')) {
            return $this->sendError(
                'Missing input.',
                ['error' => 'Type item name/title or upload an image.'],
                422
            );
        }

        try {
            $prepared = $this->prepareAiListingData($request);
        } catch (\RuntimeException $exception) {
            return $this->sendError(
                'AI image analysis failed.',
                [
                    'error' => $exception->getMessage(),
                    'fix' => 'Check GEMINI_USE_AI=true, GEMINI_API_KEY, internet connection, and Gemini model name.',
                ],
                422
            );
        }

        return $this->sendResponse($prepared, 'AI listing preview generated successfully.');
    }

    public function aiCreate(Request $request): JsonResponse
    {
        $user = $request->user();

        $allowedListingRoles = ['customer', 'company', 'institution', 'admin'];

        if (!in_array($user->role, $allowedListingRoles, true)) {
            return $this->sendError(
                'Access denied.',
                ['error' => 'Only customer, company, institution or admin can create AI waste listing.'],
                403
            );
        }

        $validator = Validator::make($request->all(), [
            'institution_id' => ['nullable', 'exists:users,id'],

            'name' => ['nullable', 'string', 'max:255'],
            'title' => ['nullable', 'string', 'max:255'],
            'description' => ['nullable', 'string'],
            'quantity' => ['nullable', 'integer', 'min:1'],
            'waste_category_id' => ['nullable', 'exists:waste_categories,id'],

            'image' => ['nullable', 'image', 'mimes:jpg,jpeg,png,webp', 'max:5120'],
            'photo_type' => ['nullable', Rule::in([
                'main',
                'front',
                'back',
                'side',
                'serial_number',
                'damage',
                'other',
            ])],

            'pickup_address' => ['nullable', 'string'],
            'district' => ['nullable', 'string', 'max:100'],
            'sector' => ['nullable', 'string', 'max:100'],
            'cell' => ['nullable', 'string', 'max:100'],
            'village' => ['nullable', 'string', 'max:100'],
            'latitude' => ['nullable', 'numeric'],
            'longitude' => ['nullable', 'numeric'],
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation Error.', $validator->errors(), 422);
        }

        if (!$request->filled('name') && !$request->filled('title') && !$request->hasFile('image')) {
            return $this->sendError(
                'Missing input.',
                ['error' => 'Type item name/title or upload an image.'],
                422
            );
        }

        try {
            $prepared = $this->prepareAiListingData($request);
        } catch (\RuntimeException $exception) {
            return $this->sendError(
                'AI image analysis failed.',
                [
                    'error' => $exception->getMessage(),
                    'fix' => 'Check GEMINI_USE_AI=true, GEMINI_API_KEY, internet connection, and Gemini model name.',
                ],
                422
            );
        }

        $category = $prepared['category'];
        $ai = $prepared['ai_result'];

        if ($this->isNoWasteAnalysis($ai)) {
            return $this->sendError(
                'No e-waste detected.',
                [
                    'error' => 'The uploaded image does not contain visible e-waste items. Listing was not created.',
                    'ai_result' => $ai,
                ],
                422
            );
        }

        $result = DB::transaction(function () use ($request, $user, $category, $ai) {
            $quantity = max((int) ($ai['quantity'] ?? $request->input('quantity', 1)), 1);
            $estimatedWeight = $this->numberOrNull($ai['estimated_weight_kg'] ?? null);
            $expectedPrice = $this->numberOrNull($ai['expected_price'] ?? null);

            $listing = WasteListing::create([
                'institution_id' => $user->role === 'admin'
                    ? $request->input('institution_id', $user->id)
                    : $user->id,

                'waste_category_id' => $category?->id,

                'title' => (string) (
                    $ai['title']
                    ?? $ai['detected_item']
                    ?? $request->input('title')
                    ?? $request->input('name')
                    ?? 'E-Waste Listing'
                ),

                'description' => (string) (
                    $request->input('description')
                    ?: ($ai['description'] ?? $ai['analysis_note'] ?? null)
                ),

                'quantity' => $quantity,
                'estimated_weight_kg' => $estimatedWeight,
                'expected_price' => $expectedPrice,
                'currency' => 'RWF',

                'pickup_address' => $request->input('pickup_address'),
                'district' => $request->input('district'),
                'sector' => $request->input('sector'),
                'cell' => $request->input('cell'),
                'village' => $request->input('village'),
                'latitude' => $request->input('latitude'),
                'longitude' => $request->input('longitude'),

                'ai_detected_item' => $ai['detected_item'] ?? null,
                'ai_detected_category' => $category?->name ?? ($ai['detected_category_name'] ?? null),
                'ai_waste_nature' => $category?->waste_nature ?? ($ai['waste_nature'] ?? null),
                'ai_is_e_waste' => (bool) ($ai['is_e_waste'] ?? true),
                'ai_estimated_weight_kg' => $estimatedWeight,
                'ai_confidence' => $this->numberOrNull($ai['confidence'] ?? 70),
                'ai_analysis_note' => $ai['analysis_note'] ?? null,

                'status' => 'ai_analyzed',
            ]);

            $photo = null;

            if ($request->hasFile('image')) {
                $file = $request->file('image');
                $path = $file->store('waste_photos', 'public');

                WastePhoto::where('waste_listing_id', $listing->id)->update([
                    'is_primary' => false,
                ]);

                $photo = WastePhoto::create([
                    'waste_listing_id' => $listing->id,
                    'uploaded_by' => $user->id,
                    'photo_path' => $path,
                    'original_name' => $file->getClientOriginalName(),
                    'mime_type' => $file->getMimeType(),
                    'file_size' => $file->getSize(),
                    'storage_disk' => 'public',
                    'photo_type' => $request->input('photo_type', 'main'),
                    'is_primary' => true,
                    'sort_order' => 0,
                    'is_ai_processed' => true,
                    'ai_processed_at' => now(),
                    'status' => 'active',
                ]);
            }

            $analysis = WasteAiAnalysis::create([
                'waste_listing_id' => $listing->id,
                'waste_photo_id' => $photo?->id,
                'ai_provider' => 'gemini',
                'ai_model' => $this->getGeminiModel(),

                'detected_item' => $ai['detected_item'] ?? $listing->title,
                'detected_category_id' => $category?->id,
                'detected_category_name' => $category?->name ?? ($ai['detected_category_name'] ?? null),

                'waste_nature' => $category?->waste_nature ?? ($ai['waste_nature'] ?? null),
                'is_e_waste' => (bool) ($ai['is_e_waste'] ?? true),
                'is_hazardous' => (bool) ($category?->is_hazardous ?? ($ai['is_hazardous'] ?? false)),

                'quantity_detected' => $quantity,
                'estimated_weight_kg' => $estimatedWeight,
                'min_estimated_weight_kg' => $category?->min_weight_kg,
                'max_estimated_weight_kg' => $category?->max_weight_kg,
                'confidence' => $this->numberOrNull($ai['confidence'] ?? 70),

                'analysis_note' => $ai['analysis_note'] ?? null,
                'analysis_result' => $ai,

                'status' => 'completed',
                'analyzed_at' => now(),
            ]);

            return [
                'listing' => $listing->fresh()->load([
                    'institution:id,name,email,role,institution_name,phone',
                    'category',
                    'primaryPhoto',
                    'aiAnalyses',
                ]),
                'photo' => $photo,
                'analysis' => $analysis->fresh()->load(['detectedCategory']),
                'ai_result' => $ai,
            ];
        });

        return $this->sendResponse($result, 'AI waste listing created successfully.');
    }

    public function show(Request $request, WasteListing $wasteListing): JsonResponse
    {
        if (!$this->canView($request->user(), $wasteListing)) {
            return $this->sendError(
                'Access denied.',
                ['error' => 'You cannot view this waste listing.'],
                403
            );
        }

        $wasteListing->load([
            'institution:id,name,email,role,institution_name,phone',
            'category',
            'photos',
            'aiAnalyses',
            'verifications',
            'offers',
            'pickups',
            'qrTags',
        ]);

        return $this->sendResponse($wasteListing, 'Waste listing retrieved successfully.');
    }

    public function update(Request $request, WasteListing $wasteListing): JsonResponse
    {
        $user = $request->user();

        if (!$this->isAdmin($user) && $wasteListing->institution_id !== $user->id) {
            return $this->sendError(
                'Access denied.',
                ['error' => 'You cannot update this listing.'],
                403
            );
        }

        if (!$this->isAdmin($user) && !in_array($wasteListing->status, ['pending', 'rejected', 'cancelled'], true)) {
            return $this->sendError(
                'Update denied.',
                ['error' => 'You can only update pending, rejected, or cancelled listings.'],
                403
            );
        }

        $validator = Validator::make($request->all(), [
            'waste_category_id' => ['nullable', 'exists:waste_categories,id'],
            'title' => ['sometimes', 'required', 'string', 'max:255'],
            'description' => ['nullable', 'string'],
            'quantity' => ['nullable', 'integer', 'min:1'],
            'estimated_weight_kg' => ['nullable', 'numeric', 'min:0'],
            'expected_price' => ['nullable', 'numeric', 'min:0'],
            'pickup_address' => ['nullable', 'string'],
            'district' => ['nullable', 'string', 'max:100'],
            'sector' => ['nullable', 'string', 'max:100'],
            'cell' => ['nullable', 'string', 'max:100'],
            'village' => ['nullable', 'string', 'max:100'],
            'latitude' => ['nullable', 'numeric'],
            'longitude' => ['nullable', 'numeric'],
            'status' => ['nullable', Rule::in([
                'pending',
                'ai_analyzed',
                'verified',
                'offer_sent',
                'offer_accepted',
                'pickup_scheduled',
                'collected',
                'completed',
                'rejected',
                'cancelled',
            ])],
        ]);

        if ($validator->fails()) {
            return $this->sendError('Validation Error.', $validator->errors(), 422);
        }

        $wasteListing->update($request->only([
            'waste_category_id',
            'title',
            'description',
            'quantity',
            'estimated_weight_kg',
            'expected_price',
            'pickup_address',
            'district',
            'sector',
            'cell',
            'village',
            'latitude',
            'longitude',
            'status',
        ]));

        return $this->sendResponse(
            $wasteListing->fresh()->load(['institution:id,name,email,role,institution_name', 'category']),
            'Waste listing updated successfully.'
        );
    }

    public function destroy(Request $request, WasteListing $wasteListing): JsonResponse
    {
        $user = $request->user();

        if (!$this->isAdmin($user) && $wasteListing->institution_id !== $user->id) {
            return $this->sendError(
                'Access denied.',
                ['error' => 'You cannot delete this listing.'],
                403
            );
        }

        if (!$this->isAdmin($user) && $wasteListing->status !== 'pending') {
            return $this->sendError(
                'Delete denied.',
                ['error' => 'Only pending listings can be deleted.'],
                403
            );
        }

        $wasteListing->delete();

        return $this->sendResponse([], 'Waste listing deleted successfully.');
    }

    private function prepareAiListingData(Request $request): array
    {
        $categories = WasteCategory::query()
            ->where('status', 'active')
            ->get();

        $analysis = $this->generateGeminiListingAnalysis($request, $categories);

        if (!is_array($analysis)) {
            if ($request->hasFile('image')) {
                throw new \RuntimeException(
                    'Gemini did not return a valid image analysis. The system refused to use fake fallback rows for this image.'
                );
            }

            $analysis = $this->fallbackListingAnalysis(
                (string) ($request->input('name') ?: $request->input('title') ?: ''),
                false
            );
        }

        if ($this->isNoWasteAnalysis($analysis)) {
            $analysis['detected_item'] = $analysis['detected_item'] ?? 'No e-waste detected';
            $analysis['title'] = $analysis['title'] ?? 'No E-Waste Detected in Image';
            $analysis['description'] = $analysis['description'] ?? 'No visible e-waste items were detected in the uploaded image.';
            $analysis['detected_category_id'] = null;
            $analysis['detected_category_name'] = null;
            $analysis['waste_nature'] = 'ibitabora';
            $analysis['is_e_waste'] = false;
            $analysis['is_hazardous'] = false;
            $analysis['quantity'] = 0;
            $analysis['estimated_weight_kg'] = 0;
            $analysis['expected_price'] = 0;
            $analysis['currency'] = 'RWF';
            $analysis['confidence'] = $analysis['confidence'] ?? 80;
            $analysis['condition'] = 'not_applicable';
            $analysis['load_type'] = 'no_waste';
            $analysis['item_breakdown'] = [];
            $analysis['analysis_note'] = $analysis['analysis_note']
                ?? 'No e-waste items were detected in the uploaded image. Listing should not be created.';

            return [
                'category' => null,
                'ai_result' => $this->sanitizeAiResult($analysis),
            ];
        }

        $loadType = $this->detectLoadType($analysis, $request);
        $analysis['load_type'] = $loadType;

        $itemBreakdown = $this->normalizeItemBreakdownFromCategories($analysis, $categories);

        if (!count($itemBreakdown)) {
            $itemBreakdown = $this->fallbackBreakdownFromCategories($analysis, $categories, $loadType, $request->hasFile('image'));
        }

        $breakdownWeight = $this->sumBreakdownWeight($itemBreakdown);
        $breakdownPrice = $this->sumBreakdownPrice($itemBreakdown);

        if ($loadType === 'bulk_pile' && $breakdownWeight > 0 && $breakdownWeight < 50) {
            $bulkCategory = $this->findBulkCategory($categories);
            $missingWeight = 150 - $breakdownWeight;

            if ($missingWeight > 0) {
                $unitPrice = $this->numberOrNull($bulkCategory?->price_per_kg) ?: 700;

                $itemBreakdown[] = [
                    'item_name' => 'Uncounted mixed e-waste batch',
                    'category_id' => $bulkCategory?->id,
                    'category_name' => $bulkCategory?->name ?? 'Mixed E-Waste',
                    'category_slug' => $bulkCategory?->slug ?? 'mixed_e_waste_bulk_pile',
                    'quantity' => 1,
                    'unit_weight_kg' => round($missingWeight, 2),
                    'total_weight_kg' => round($missingWeight, 2),
                    'price_per_kg' => $unitPrice,
                    'price_per_item' => 0,
                    'line_expected_price' => round($missingWeight * $unitPrice, 2),
                    'confidence' => 55,
                    'reason' => 'Added because a bulk pile cannot realistically weigh below 50 kg. Staff verification required.',
                ];
            }

            $breakdownWeight = $this->sumBreakdownWeight($itemBreakdown);
            $breakdownPrice = $this->sumBreakdownPrice($itemBreakdown);
        }

        $category = $this->selectListingCategory($request, $analysis, $itemBreakdown, $categories);

        $quantity = (int) ($request->input('quantity') ?: ($analysis['quantity'] ?? 1));
        $quantity = max($quantity, 1);

        $estimatedWeight = $breakdownWeight > 0
            ? $breakdownWeight
            : $this->numberOrNull($analysis['estimated_weight_kg'] ?? null);

        if ($loadType === 'bulk_pile' && (!$estimatedWeight || $estimatedWeight < 50)) {
            $estimatedWeight = 150;
        }

        if (!$estimatedWeight && $category && $category->average_weight_kg) {
            $estimatedWeight = $quantity * (float) $category->average_weight_kg;
        }

        if (!$estimatedWeight) {
            $estimatedWeight = $loadType === 'bulk_pile'
                ? 150
                : ($quantity * 1);
        }

        $expectedPrice = $breakdownPrice > 0
            ? $breakdownPrice
            : (
                $category
                    ? $this->calculateExpectedPrice($category, $quantity, $estimatedWeight, $loadType)
                    : $this->numberOrNull($analysis['expected_price'] ?? null)
            );

        if (!$expectedPrice) {
            $expectedPrice = $loadType === 'bulk_pile'
                ? ((float) $estimatedWeight * 700)
                : ($quantity * 1500);
        }

        $detectedNames = collect($itemBreakdown)
            ->map(fn ($item) => $item['item_name'] ?? null)
            ->filter()
            ->take(6)
            ->implode(', ');

        $analysis['quantity'] = $quantity;
        $analysis['estimated_weight_kg'] = round((float) $estimatedWeight, 2);
        $analysis['expected_price'] = round((float) $expectedPrice, 2);
        $analysis['currency'] = 'RWF';
        $analysis['item_breakdown'] = $itemBreakdown;

        $analysis['detected_item'] = $detectedNames ?: ($analysis['detected_item'] ?? 'E-Waste Item');
        $analysis['detected_category_id'] = $category?->id;
        $analysis['detected_category_name'] = $category?->name ?? ($analysis['detected_category_name'] ?? null);
        $analysis['waste_nature'] = $category?->waste_nature ?? ($analysis['waste_nature'] ?? 'ibitabora');
        $analysis['is_hazardous'] = (bool) ($category?->is_hazardous ?? ($analysis['is_hazardous'] ?? false));

        if ($loadType === 'bulk_pile') {
            $analysis['is_hazardous'] = true;
        }

        if (empty($analysis['title'])) {
            $analysis['title'] = $loadType === 'bulk_pile'
                ? 'Bulk Mixed E-Waste Collection'
                : ($analysis['detected_item'] ?? $request->input('title') ?? $request->input('name') ?? 'E-Waste Listing');
        }

        if (empty($analysis['description'])) {
            $analysis['description'] = $analysis['analysis_note'] ?? 'Electronic waste item prepared for collection and recycling.';
        }

        if (empty($analysis['analysis_note'])) {
            $analysis['analysis_note'] = $loadType === 'bulk_pile'
                ? 'AI detected multiple e-waste items from the photo and matched each item with the standard category library. Final weight must be verified by staff.'
                : 'AI detected the e-waste item and matched it with the standard category library. Staff verification is recommended.';
        }

        return [
            'category' => $category,
            'ai_result' => $this->sanitizeAiResult($analysis),
        ];
    }

    private function generateGeminiListingAnalysis(Request $request, $categories): ?array
    {
        if (!$this->getGeminiUseAi() || !$this->getGeminiApiKey()) {
            return null;
        }

        $categoryList = $categories
            ->map(function (WasteCategory $category) {
                return [
                    'id' => $category->id,
                    'name' => $category->name,
                    'slug' => $category->slug,
                    'waste_nature' => $category->waste_nature,
