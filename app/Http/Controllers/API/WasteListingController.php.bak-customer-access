    private function matchItemCategory(string $itemName, string $categoryName, $categories): ?WasteCategory
    {
        $item = strtolower(trim($itemName));
        $cat = strtolower(trim($categoryName));

        foreach ($categories as $category) {
            $name = strtolower((string) $category->name);
            $slug = strtolower((string) $category->slug);

            if ($cat !== '' && ($cat === $name || $cat === $slug || str_contains($name, $cat) || str_contains($cat, $name))) {
                return $category;
            }

            if ($item !== '' && ($item === $name || str_contains($item, $name) || str_contains($name, $item))) {
                return $category;
            }
        }

        $aliases = [
            'cpu' => ['desktop_cpu_tower', 'desktop cpu tower'],
            'tower' => ['desktop_cpu_tower', 'desktop cpu tower'],
            'desktop' => ['desktop_cpu_tower', 'desktop cpu tower'],
            'lcd' => ['lcd_monitor', 'lcd monitor'],
            'screen' => ['lcd_monitor', 'lcd monitor'],
            'crt' => ['crt_monitor', 'crt monitor'],
            'keyboard' => ['keyboard'],
            'mouse' => ['mouse'],
            'printer' => ['small_printer', 'small printer'],
            'copier' => ['large_printer_copier', 'large printer / copier'],
            'ups' => ['ups'],
            'battery' => ['small_battery', 'small battery'],
            'cable' => ['cable_batch', 'cable batch'],
            'motherboard' => ['motherboard'],
            'circuit' => ['circuit_board_batch', 'circuit board batch'],
            'phone' => ['mobile_phone', 'mobile phone'],
            'tablet' => ['tablet'],
            'router' => ['network_router', 'network router'],
            'switch' => ['network_switch', 'network switch'],
        ];

        $combined = "{$item} {$cat}";

        foreach ($aliases as $keyword => $targets) {
            if (!str_contains($combined, $keyword)) {
                continue;
            }

            foreach ($categories as $category) {
                $name = strtolower((string) $category->name);
                $slug = strtolower((string) $category->slug);

                foreach ($targets as $target) {
                    if ($slug === $target || $name === $target || str_contains($slug, str_replace(' ', '_', $target))) {
                        return $category;
                    }
                }
            }
        }

        return null;
    }

    private function selectListingCategory(Request $request, array $analysis, array $itemBreakdown, $categories): ?WasteCategory
    {
        if ($this->isNoWasteAnalysis($analysis)) {
            return null;
        }

        if ($request->filled('waste_category_id')) {
            return WasteCategory::find($request->input('waste_category_id'));
        }

        $loadType = (string) ($analysis['load_type'] ?? 'single_item');

        if ($loadType === 'bulk_pile') {
            $bulkCategory = $this->findBulkCategory($categories);

            if ($bulkCategory) {
                return $bulkCategory;
            }
        }

        $topItem = collect($itemBreakdown)
            ->sortByDesc(fn ($item) => (float) ($item['total_weight_kg'] ?? 0))
            ->first();

        if ($topItem && !empty($topItem['category_id'])) {
            return WasteCategory::find($topItem['category_id']);
        }

        return $this->matchCategory($request, $analysis, $categories);
    }

    private function matchCategory(Request $request, array $analysis, $categories): ?WasteCategory
    {
        if ($this->isNoWasteAnalysis($analysis)) {
            return null;
        }

        if ($request->filled('waste_category_id')) {
            return WasteCategory::find($request->input('waste_category_id'));
        }

        if (!empty($analysis['detected_category_id'])) {
            $category = WasteCategory::find($analysis['detected_category_id']);

            if ($category) {
                return $category;
            }
        }

        $categoryName = strtolower((string) ($analysis['detected_category_name'] ?? ''));
        $itemName = strtolower((string) ($analysis['detected_item'] ?? ''));

        return $this->matchItemCategory($itemName, $categoryName, $categories);
    }

    private function findBulkCategory($categories): ?WasteCategory
    {
        $keywords = [
            'mixed_e_waste_bulk_pile',
            'mixed',
            'bulk',
            'general',
            'electronic',
            'electronics',
            'e-waste',
            'ewaste',
            'waste',
        ];

        foreach ($categories as $category) {
            $name = strtolower((string) $category->name);
            $slug = strtolower((string) $category->slug);

            foreach ($keywords as $keyword) {
                if (str_contains($name, $keyword) || str_contains($slug, $keyword)) {
                    return $category;
                }
            }
        }

        return null;
    }

    private function calculateExpectedPrice(
        WasteCategory $category,
        int $quantity,
        mixed $estimatedWeight,
        string $loadType = 'single_item'
    ): float {
        $weight = (float) ($estimatedWeight ?: 0);

        if ((float) $category->price_per_kg > 0 && $weight > 0) {
            return round($weight * (float) $category->price_per_kg, 2);
        }

        if ((float) $category->price_per_item > 0) {
            return round($quantity * (float) $category->price_per_item, 2);
        }

        return 0;
    }

    private function sumBreakdownWeight(array $items): float
    {
        return round(array_reduce($items, function ($total, $item) {
            return $total + (float) ($item['total_weight_kg'] ?? 0);
        }, 0), 2);
    }

    private function sumBreakdownPrice(array $items): float
    {
        return round(array_reduce($items, function ($total, $item) {
            return $total + (float) ($item['line_expected_price'] ?? 0);
        }, 0), 2);
    }

