            'quantity' => $loadType === 'no_waste'
                ? 0
                : max((int) ($analysis['quantity'] ?? 1), 1),
            'estimated_weight_kg' => round((float) $estimatedWeight, 2),
            'expected_price' => round((float) $expectedPrice, 2),
            'currency' => 'RWF',
            'confidence' => min(max((float) ($analysis['confidence'] ?? 70), 0), 100),
            'condition' => (string) ($analysis['condition'] ?? 'used'),
            'load_type' => $loadType,
